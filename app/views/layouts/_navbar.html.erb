<nav class="navbar navbar-expand-lg bg-body-tertiary">
  <div class="container">
    <%= link_to 'Rails Blog', root_path, class: "navbar-brand fw-bold" %>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarText" aria-controls="navbarText" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarText">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item">
          <%= link_to 'All posts', posts_path, class: 'nav-link' %>
        </li>
        <% if user_signed_in? %>
          <li class="nav-item">
            <%= link_to 'Create post', new_post_path, class: 'nav-link' %>
          </li>
        <% end %>
      </ul>
      <div class="d-flex align-items-center gap-3">
        <% if user_signed_in? %>
          <div class="d-block">
            <%= current_user.email %>
          </div>
          <%= button_to "Sign out", destroy_user_session_path, method: :delete, class: "btn btn-outline-dark btn-sm " %>
        <% else %>
          <%= link_to 'Sign In', new_user_session_path, class: "btn btn-outline-dark btn-sm" %>
          <%= link_to 'Sign Up', new_user_registration_path, class: "btn btn-dark btn-sm" %>
        <% end %>
      </div>
    </div>
  </div>
</nav>